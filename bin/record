#!/usr/bin/env bash

set -o nounset
# set -o errexit  # do not enable errexit, otherwise then you Ctrl+C to stop the
                  # recording the program completely stop and the last instructions
                  # are not executed
# set -o pipefail


log () {
    echo >&2 "${1}"
}

now=$(date "+%Y%m%d-%H%M%S")

output_file="${now}-audio-capture.mkv"

output_dir="$HOME/audio-captures"
mkdir -p "${output_dir}"

output_path="${output_dir}/${output_file}"

sink='alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__hw_sofhdadsp__sink.monitor'
sink='alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Speaker__sink.monitor'
sink='alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Headphones__sink.monitor'
mic='alsa_input.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Mic1__source'  # usually laptop
mic='alsa_input.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Mic2__source'  # usually headphones

# write each stream into a different track within the same file
# do not compress (to minimize CPU/memory consumption)
# force sample rate (negligible CPU usage), to avoid tracks from shifting in post-production
# output to MKV format, to (1) use a lossless format (faster), and (2) avoid file corruption if files crash (WAV get corrupted)
ffmpeg -f pulse -i "${mic}"      \
       -f pulse -i "${sink}"     \
       -map 0:a -c:a:0 pcm_s16le \
       -ar:a:0 16000             \
       -map 1:a -c:a:1 pcm_s16le \
       -ar:a:1 16000             \
       -f matroska               \
       "${output_path}"

log ""
log ""
log "File saved at:"
echo "${output_path}"
